{
  "play": {
    "parameter_name": "game",
    "loading_message": "🎲 *Rolling the dice...*",
    "*": [
      {
        "comment": "Channel Commands, everyone in the channel can use ... except 333333333, they're in time out.",
        "permissions": {
          "blacklist_users": [333333333]
        },
        "commands": {
          "Roll a D4": { "command": "bash -c 'echo $(( (RANDOM % 4) + 1 ))'", "prepend": "🎲 **D4 Roll:** " },
          "Roll a D6": { "command": "bash -c 'echo $(( (RANDOM % 6) + 1 ))'", "prepend": "🎲 **D6 Roll:** " },
          "Roll a D8": { "command": "bash -c 'echo $(( (RANDOM % 8) + 1 ))'", "prepend": "🎲 **D8 Roll:** " },
          "Roll a D10": { "command": "bash -c 'echo $(( (RANDOM % 10) + 1 ))'", "prepend": "🎲 **D10 Roll:** " },
          "Roll a D12": { "command": "bash -c 'echo $(( (RANDOM % 12) + 1 ))'", "prepend": "🎲 **D12 Roll:** " },
          "Roll a D20": { "command": "bash -c 'echo $(( (RANDOM % 20) + 1 ))'", "prepend": "🎲 **D20 Roll:** " },
          "Roll a D100": { "command": "bash -c 'echo $(( (RANDOM % 100) + 1 ))'", "prepend": "🎲 **D100 Roll:** " },
          "GuessWhat": "echo 'Chicken butt!!'",
          "regret": "echo 'You lost THE GAME'",
          "date": "date",
          "moo": "fortune -a | cowsay",
          "mooooooooooooooo": "fortune -l | cowsay",
          "no": "/app/commands/no-as-a-service.sh"
        }
      }
    ]
  },
  "funfact": {
    "parameter_name": "about",
    "loading_message": "🕒 *Consulting the ancient scrolls...*",
    "*": [
      {
        "comment": "Standard fortune commands available globally",
        "commands": {
          "linux": {
            "command": "fortune linux",
            "prepend": "🐧 **Linux Wisdom:**\n",
            "append": "\n*-- Source: fortune-mod*"
          },
          "wisdom": "fortune wisdom"
        }
      }
    ]
  },
  "ai": {
    "parameter_name": "prompt",
    "loading_message": "🤖 *Querying Ollama AI, please wait...*",
    "all": [
      {
        "comment": "Ollama script integration",
        "commands": {
          "ask": "python3 /app/commands/query_ollama.py --prompt"
        }
      }
    ]
  },
  "runtest": {
    "parameter_name": "query",
    "123456789012345678": [
      {
        "comment": "Numerical and Logic Validation Examples",
        "commands": {
          "check_random": {
            "command": "echo $(( ( RANDOM % 10 ) + 1 ))",
            "validation": {
              ">": "5"
            }
          },
          "double_roll_match": {
            "command": "echo $(( ( RANDOM % 10 ) + 1 ))",
            "validation": {
              "==": {
                "result": {
                  "command": "echo $(( ( RANDOM % 10 ) + 1 ))"
                }
              }
            }
          }
        }
      }
    ]
  },
  "admin": {
    "parameter_name": "task",
    "123456789012345678": [
      {
        "comment": "Whitelist and Blacklist examples",
        "permissions": {
          "whitelist_roles": [111111111, 222222222],
          "blacklist_users": [444444444]
        },
        "commands": {
          "container_status": "docker ps --format 'table {{.Names}}\t{{.Status}}'"
        }
      },
      {
        "comment": "Global Blacklist - Only the OWNER_ID from .env can run this",
        "permissions": {
          "blacklist_users": ["*"]
        },
        "commands": {
          "reboot_server": "reboot"
        }
      }
    ]
  }
}
